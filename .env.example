# OpenAI Configuration (required for Streamlit/GPT mode only)
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=30

# Cost Control
MAX_SESSION_COST=0.50

# MCP Server Configuration
MCP_SERVER_CMD=python
MCP_SERVER_ARGS=mcp_server.py

# MCP Transport: stdio (default), sse, or streamable-http
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8080

# Response Mode: full (HTML + data for Streamlit) or data_only (data dict for Kore.ai)
RESPONSE_MODE=full

# Rate Limiting: requests per minute (0 = disabled)
MCP_RATE_LIMIT=0

# Logging
LOG_LEVEL=WARNING
LOG_FORMAT=text
